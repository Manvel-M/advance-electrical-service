---
import { Layout } from "@/layouts";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog"
  description="Read the latest articles and updates from our blog."
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-center py-10">Blog</h1>
    <div>
      <ul class="space-y-4">
        {
          posts.map((post) => (
            <li class="bg-surface p-6 rounded-lg shadow-md">
              <a href={`/blog/${post.slug}`}>
                <div class="flex flex-col">
                  <h3 class="flex-1">{post.data.title}</h3>
                  <p class="flex-1">{post.data.description}</p>
                  <div class="text-sm text-surface-muted italic text-end">
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Layout>
